

# --- SERVER ---
PORT=3000
# Use a comma-separated list (e.g., http://localhost:5173,http://your-vps-ip)
ALLOWED_ORIGINS=http://localhost:5173

# --- AUTH ---
JWT_SECRET=your_jwt_secret_here

# --- DATABASE (Knex/Drizzle/Supabase) ---
# Used for Local Dev
DB_HOST=your_supabase_db_host
DB_PORT=6543
DB_USER=postgres.your_project_id
DB_PASSWORD=your_db_password
DB_NAME=postgres

# Used for Production Docker (your_connection_string)
DATABASE_URL=protocol://user:password@host:port/database 

# --- SUPABASE API (Optional if only using Knex) ---
SUPABASE_URL=https://your-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key


# --- PAYMENTS ---
STRIPE_SECRET_KEY=sk_test_...
